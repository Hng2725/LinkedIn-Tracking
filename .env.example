# Credentials are auto-populated by the pairing flow on first `npm start`.
# You don't need to fill these manually.
# PRIVOS_URL=
# CLIENT_ID=
# CLIENT_SECRET=

# --- Dev mode (`npm run dev`) ---------------------------------------------
# How the hub iframe reaches the local Vite dev server (HMR + breakpoints):
#   localhost   (default) browser on the SAME machine loads http://localhost:<port>
#   cloudflared spin up a public tunnel — use when the hub is opened on another machine
# DEV_TUNNEL=localhost
# VITE_PORT=5179
# PUBLIC_URL=          # optional: reuse your own tunnel (DEV_TUNNEL=cloudflared)
